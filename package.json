{
  "name": "mosaic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "npm --prefix client run dev",
    "seed": "node -e \"import('./server/db.js').then(m => { m.seed(); console.log('seeded'); process.exit(0); })\"",
    "demo:seed": "DEMO_MODE=true node -e \"import('./server/db.js').then(m => { m.seedDemo(); process.exit(0); })\"",
    "demo:reset": "rm -f mosaic.db mosaic.db-wal mosaic.db-shm && npm run demo:seed",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
